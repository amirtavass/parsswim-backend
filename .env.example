# Environment Configuration - Rename to .env and fill in values

# Application
NODE_ENV=production
PORT=4000

# Database
MONGODB_URL=mongodb://parsswim_user:Amir6980!@localhost:27017/parsswim?authSource=admin

# Sessions & Cookies
SESSION_SECRET=your-strong-random-session-secret-min-32-chars
COOKIE_SECRET=your-strong-random-cookie-secret-min-32-chars

# Frontend URL (for CORS)
